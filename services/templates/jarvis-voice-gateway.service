[Unit]
Description=Jarvis Voice Gateway (wake-word + ASR)
After=default.target

[Service]
Type=simple
ExecStart=__VENV_PY__ __JARVIS_ROOT__/services/voice_gateway.py
Restart=on-failure
RestartSec=10s
Nice=10
Environment="PYTHONPATH=__JARVIS_ROOT__"
Environment="JARVIS_ROOT=__JARVIS_ROOT__"
Environment="VAULT_ROOT=__VAULT_ROOT__"
Environment="DISPLAY=:0"
Environment="DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/__UID__/bus"
WorkingDirectory=__JARVIS_ROOT__

[Install]
WantedBy=default.target
