[Unit]
Description=Jarvis LSP HTTP Sidecar
After=network.target

[Service]
Type=simple
ExecStart=__VENV_PY__ __JARVIS_ROOT__/services/jarvis_lsp.py
Restart=on-failure
RestartSec=10s
Nice=10
Environment="PYTHONPATH=__JARVIS_ROOT__"
Environment="JARVIS_ROOT=__JARVIS_ROOT__"
Environment="VAULT_ROOT=__VAULT_ROOT__"
WorkingDirectory=__JARVIS_ROOT__

[Install]
WantedBy=default.target
