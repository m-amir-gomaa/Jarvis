#compdef jarvis
# Jarvis CLI Zsh Completion Script v3
# Dynamically powered by 'jarvis completion'

_jarvis() {
    local ret=1
    local context state state_descr line
    typeset -A opt_args
    
    # Use JARVIS_ROOT if defined, else fallback to common location
    local jarvis_bin="${JARVIS_ROOT:-$HOME/NixOSenv/Jarvis}/jarvis.py"
    if [[ ! -x "$jarvis_bin" ]]; then
        jarvis_bin="jarvis" # Fallback to PATH
    fi
    
    local python_bin="${JARVIS_ROOT:-$HOME/NixOSenv/Jarvis}/.venv/bin/python"
    [[ ! -x "$python_bin" ]] && python_bin="python3"

    _arguments -C \
        '(-v --version)'{-v,--version}'[Show version information]' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '--short[Short one-line status for status command]' \
        '1: :->cmds' \
        '*:: :->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=("${(@f)$($python_bin "$jarvis_bin" completion commands)}")
            _describe -t commands 'jarvis commands' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                learn|ingest)
                    _arguments \
                        '--layer[Target knowledge layer]:layer:(1 2 3)' \
                        '--category[Knowledge category]:category:->categories' \
                        '*:URL or file:_files' && ret=0
                    ;;
                query)
                    _arguments \
                        '--category[Filter by category]:category:->categories' \
                        '*:Question:' && ret=0
                    ;;
                index)
                    _arguments \
                        '--category[Index category name]:category:' \
                        '--privacy[Privacy level (0-3)]:level:(0 1 2 3)' \
                        '*:Directory:_files -/' && ret=0
                    ;;
                associate)
                    _arguments \
                        '1:Action:(list remove)' \
                        '2:Category:->categories' && ret=0
                    ;;
                cap)
                    _arguments \
                        '1:Action:(list grant revoke)' \
                        '2:Capability:->capabilities' && ret=0
                    ;;
                approve)
                    _arguments \
                        '1:ID:->pending_ids' && ret=0
                    ;;
                pending)
                    # No extra args
                    ;;
                set-key)
                    _arguments \
                        '1:Provider:(anthropic openai google deepseek groq openrouter cerebras)' \
                        '2:API Key:' && ret=0
                    ;;
                config)
                    _arguments \
                        '1:Action:(set get list reset)' \
                        '2:Key:->config_keys' \
                        '3:Value:' && ret=0
                    ;;
                inbox)
                    _arguments \
                        '1:Action:(process list)' \
                        '*:: :->inbox_args' && ret=0
                    ;;
                toggle)
                    _arguments \
                        '1:Setting:(voice)' && ret=0
                    ;;
                sessions)
                    _arguments \
                        '1:Session ID:->sessions' && ret=0
                    ;;
                models|keys|status|dashboard|backup|archive|uptime|pause|resume|man|training|forget|help)
                    # Simple or no args
                    ;;
            esac
            
            # Handle dynamic categories/ids/sessions
            case $state in
                categories)
                    local -a categories
                    categories=("${(@f)$($python_bin "$jarvis_bin" completion categories)}")
                    _describe -t categories 'categories' categories && ret=0
                    ;;
                capabilities)
                    local -a caps
                    caps=("${(@f)$($python_bin "$jarvis_bin" completion capabilities)}")
                    _describe -t caps 'capabilities' caps && ret=0
                    ;;
                config_keys)
                    local -a keys
                    keys=("${(@f)$($python_bin "$jarvis_bin" completion config_keys)}")
                    _describe -t keys 'config keys' keys && ret=0
                    ;;
                pending_ids)
                    local -a ids
                    ids=("${(@f)$($python_bin "$jarvis_bin" completion pending_ids)}")
                    _describe -t ids 'pending IDs' ids && ret=0
                    ;;
                sessions)
                    local -a sessions
                    sessions=("${(@f)$($python_bin "$jarvis_bin" completion sessions)}")
                    _describe -t sessions 'sessions' sessions && ret=0
                    ;;
            esac
            
            # Handle nested inbox process
            if [[ $line[1] == "inbox" && $line[2] == "process" ]]; then
                local -a inbox_ids
                inbox_ids=("${(@f)$($python_bin "$jarvis_bin" completion inbox)}")
                _describe -t ids 'inbox IDs' inbox_ids && ret=0
            fi
            ;;
    esac

    return ret
}

_jarvis "$@"
